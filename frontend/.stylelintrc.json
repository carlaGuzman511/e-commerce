{
  "syntax": "scss",
  "plugins": [
    "stylelint-scss",
    "stylelint-order"
  ],
  "extends": [
    "stylelint-config-standard-scss"
  ],
  "rules": {
    "order/properties-alphabetical-order": true,
    "at-rule-no-unknown": null,
    "scss/at-rule-no-unknown": true,
    "declaration-no-important": true,
    "scss/color-no-hex": true,
    "color-named": "never",
    "function-disallowed-list": [
      "rgb",
      "rgba",
      "hsl",
      "hsla"
    ]
  },
  "ignoreFiles": [
    "**/node_modules/**"
  ]
}
